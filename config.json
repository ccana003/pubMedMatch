{
  "name": "CorePubMatch",
  "namespace": "UniversityofMiami\\CorePubMatch",
  "description": "Project-level PubMed matching and adjudication tool",
  "documentation": "README.md",
  "authors": [
    {
      "name": "Carlos A. Canales",
      "email": "ccanales2@miami.edu",
      "institution": "University of Miami"
    }
  ],
  "permissions": [
    "redcap_every_page_top"
  ],
  "project-settings": [
    {
      "key": "investigator_names",
      "name": "Investigator entries (Name or Name, email)",
      "type": "textarea",
      "required": true
    },
    {
      "key": "start_date",
      "name": "Start date (YYYY/MM/DD)",
      "type": "text",
      "required": true
    },
    {
      "key": "end_date",
      "name": "End date (YYYY/MM/DD)",
      "type": "text",
      "required": true
    },
    {
      "key": "core_name",
      "name": "Core name (used to prefill core review rows)",
      "type": "text"
    },
    {
      "key": "enable_cron",
      "name": "Enable cron (optional for future use)",
      "type": "checkbox"
    },
    {
      "key": "enable_notifications",
      "name": "Enable outbound PI notifications",
      "type": "checkbox"
    },
    {
      "key": "email_subject_template",
      "name": "Email subject template (optional, supports {{pi_name}})",
      "type": "text"
    },
    {
      "key": "email_intro_template",
      "name": "Email intro template (optional HTML, supports {{pi_name}})",
      "type": "textarea"
    }
  ]
}
